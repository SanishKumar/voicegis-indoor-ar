{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voicegis.dev/schema/indoor-building-source/0.1.0",
  "title": "VoiceGIS indoor building source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "building",
    "floors",
    "spaces",
    "portals",
    "verticalConnectors",
    "pois",
    "localizationAnchors"
  ],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "building": { "$ref": "#/$defs/building" },
    "floors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/floor" }
    },
    "spaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/space" }
    },
    "portals": {
      "type": "array",
      "items": { "$ref": "#/$defs/portal" }
    },
    "verticalConnectors": {
      "type": "array",
      "items": { "$ref": "#/$defs/verticalConnector" }
    },
    "pois": {
      "type": "array",
      "items": { "$ref": "#/$defs/poi" }
    },
    "localizationAnchors": {
      "type": "array",
      "items": { "$ref": "#/$defs/localizationAnchor" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "coordinate2d": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "coordinate3d": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "polygon": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/coordinate2d" }
    },
    "building": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "units", "entrySpaceId", "coordinateSystem"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "units": { "const": "meters" },
        "entrySpaceId": { "$ref": "#/$defs/id" },
        "coordinateSystem": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "origin", "northOffsetDegrees"],
          "properties": {
            "type": { "const": "local-cartesian" },
            "origin": { "$ref": "#/$defs/coordinate3d" },
            "northOffsetDegrees": {
              "type": "number",
              "minimum": -180,
              "exclusiveMaximum": 180
            }
          }
        }
      }
    },
    "floor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "level", "elevation", "clearHeight", "outline"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "level": { "type": "integer" },
        "elevation": { "type": "number" },
        "clearHeight": { "type": "number", "exclusiveMinimum": 0 },
        "outline": { "$ref": "#/$defs/polygon" }
      }
    },
    "space": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "floorId", "name", "type", "polygon", "public", "accessible"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "floorId": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "type": {
          "enum": [
            "entrance",
            "room",
            "corridor",
            "lobby",
            "service",
            "restricted",
            "vertical-circulation"
          ]
        },
        "polygon": { "$ref": "#/$defs/polygon" },
        "public": { "type": "boolean" },
        "accessible": { "type": "boolean" }
      }
    },
    "portal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "floorId", "kind", "connects", "position", "width", "accessible"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "floorId": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["door", "opening", "gate"] },
        "connects": {
          "type": "array",
          "prefixItems": [{ "$ref": "#/$defs/id" }, { "$ref": "#/$defs/id" }],
          "items": false,
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "position": { "$ref": "#/$defs/coordinate2d" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "accessible": { "type": "boolean" },
        "restricted": { "type": "boolean", "default": false }
      }
    },
    "connectorStop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["floorId", "spaceId", "position"],
      "properties": {
        "floorId": { "$ref": "#/$defs/id" },
        "spaceId": { "$ref": "#/$defs/id" },
        "position": { "$ref": "#/$defs/coordinate2d" }
      }
    },
    "verticalConnector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "accessible", "stops"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "kind": { "enum": ["elevator", "stairs", "ramp", "escalator"] },
        "accessible": { "type": "boolean" },
        "restricted": { "type": "boolean", "default": false },
        "stops": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/connectorStop" }
        }
      }
    },
    "poi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "floorId",
        "spaceId",
        "name",
        "category",
        "position",
        "public",
        "accessible"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "floorId": { "$ref": "#/$defs/id" },
        "spaceId": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "category": { "type": "string", "minLength": 1, "maxLength": 80 },
        "position": { "$ref": "#/$defs/coordinate2d" },
        "public": { "type": "boolean" },
        "accessible": { "type": "boolean" },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 120 }
        }
      }
    },
    "localizationAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "floorId", "spaceId", "kind", "position", "headingDegrees", "payload"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "floorId": { "$ref": "#/$defs/id" },
        "spaceId": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["qr", "apriltag", "image", "nfc"] },
        "position": { "$ref": "#/$defs/coordinate2d" },
        "headingDegrees": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "payload": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    }
  }
}
